<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full h-full bg-zinc-900 text-white p-10">
        <a class="text-blue-500" href="/">back to home</a>
        <h1 class="text-3xl tracking-tighter mb-3 mt-5">All Users</h1>
        <div class="users flex gap-3 flex-wrap" >
            <% if (users.length > 0) { %>
                <% users.forEach(user => { %>
             <div class="user w-72 p-4 bg-zinc-800 rounded-lg">
                <div class="w-full h-72 bg-zinc-700 rounded-lg">
                    <img class="w-full h-full object-top" src="<%= user.image %>" alt="<%= user.name %>">
                </div>
                <h3 class="text-2xl tracking-tighter mt-2"><%= user.name %></h3>
                <h5 class="text-zinc-500"><%= user.email %></h5>
                <div class="flex gap-3 mt-5">
                    <a class="text-blue-400" href="/edit/<%= user._id %>">Edit</a>
                    <a class="text-red-300" href="/delete/<%= user._id %>">Delete</a>
                </div>
            </div>
            <% }) %>
            <% } else{ %>
                    <h3 class="text-zinc-500">no users yet</h3>
            <% } %>
        </div>
    </div>
</body>
</html>